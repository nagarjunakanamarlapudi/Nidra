# ======================================================================
# Pragya Personal Assistant — environment configuration
# Copy to .env and fill in. NEVER commit .env.
# ======================================================================

# ---- App ----
APP_ENV=local                       # local | staging | production
LOG_LEVEL=INFO
# Used for encryption-at-rest of secrets and signing. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=change-me-to-a-long-random-string

# ---- Single-user auth ----
# Bearer token the web app / API clients must present.
API_AUTH_TOKEN=change-me-to-a-long-random-string

# ---- Database (Postgres + pgvector) ----
# Inside Docker Compose the host is "db"; for local-without-docker use "localhost".
DATABASE_URL=postgresql+asyncpg://pragya:pragya@db:5432/pragya

# ---- Compose ----
# Host port the API is published on (the container always listens on 8000).
APP_PORT=8000
# Web app host port + the API base the browser uses (must match APP_PORT).
WEB_PORT=3000
NEXT_PUBLIC_API_BASE=http://localhost:8000
# Public base URL of the web app (frontend) — the OAuth callback redirects the
# browser back here, to the marketplace, when done.
APP_BASE_URL=http://localhost:3000
# Public base URL of the BACKEND API, where the OAuth callback route lives. This
# value + "/connectors/oauth/callback" is the EXACT redirect URI you register in
# Google. Defaults to APP_BASE_URL (correct when web+api share one domain in prod).
# For local split ports, set it to the API URL — match your APP_PORT, e.g.:
OAUTH_REDIRECT_BASE_URL=http://localhost:8088
# Postgres credentials for the Compose db service. Use a strong password for
# anything beyond local (and set APP_ENV=production to enforce strong app secrets).
POSTGRES_USER=pragya
POSTGRES_PASSWORD=pragya
POSTGRES_DB=pragya

# ---- Agent engine (the brain) ----
# One selector across all plug categories:
#   coding-agent subscriptions: claude-code, codex
#   model API keys:             anthropic-api, openai-api
#   local LLM:                  ollama
# claude-code uses your Claude subscription; codex uses your ChatGPT subscription;
# anthropic-api/openai-api use the matching key below; ollama is local.
AGENT_ENGINE=claude-code
# Model for the loop-based brains (anthropic-api / openai-api / ollama):
LLM_CHAT_MODEL=claude-opus-4-8

# Claude subscription token for AGENT_ENGINE=claude-code — REQUIRED in Docker
# (the macOS Keychain isn't reachable inside the container). On your host run:
#   claude setup-token
# then paste the printed token here. Keep ANTHROPIC_API_KEY empty so it wins.
# (Pragya isolates Claude Code's sessions/transcripts in their own config dir —
#  ~/.pragya-assistant locally, /home/pragya/.pragya-assistant in Docker — separate
#  from your personal ~/.claude. Wired via the Makefile + compose, not here.)
CLAUDE_CODE_OAUTH_TOKEN=

# Embeddings provider + model + dimension. provider ∈ {openai, ollama}
LLM_EMBEDDING_PROVIDER=openai
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_EMBEDDING_DIM=1536

# Provider credentials / endpoints (only the ones you use are required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ---- Telegram (now a connector) ----
# On first boot these SEED the "Telegram" channel connector (the bot's long-poll
# worker then runs in-process in the backend, managed from the Connectors UI).
# Thereafter manage it there. Kept here so existing setups keep working.
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs allowed to talk to the bot (your own; groups are negative).
TELEGRAM_ALLOWED_CHAT_IDS=

# ---- Digest (proactive daily summary) ----
# Composed by the engine, stored for the web app, and pushed to the Telegram
# chats above. Fires daily at DIGEST_HOUR:DIGEST_MINUTE in DIGEST_TIMEZONE.
DIGEST_ENABLED=true
DIGEST_HOUR=8
DIGEST_MINUTE=0
# Nightly dreamer (sidecar): refresh Opinions from signals, then dream. Default 00:00.
DREAM_HOUR=0
DREAM_MINUTE=0
# Finance sync schedule (sidecar also reads these)
FINANCE_SYNC_HOUR=6
FINANCE_SYNC_MINUTE=30
# IANA timezone name (NOT an abbreviation), e.g. America/Los_Angeles, Asia/Kolkata
DIGEST_TIMEZONE=UTC

# ---- Connectors platform ----
# Connectors (Google Calendar, Gmail, …) are enabled from the in-app Connectors
# marketplace, not here — their per-account credentials/tokens live encrypted in
# Postgres, not in this file. (Plaid + Telegram below are still configured here.)
#
# OPTIONAL: register one Google Cloud OAuth client (Web app) and set these for a
# pure one-click "Connect with Google". Redirect URI to register:
#   {APP_BASE_URL}/connectors/oauth/callback
# You don't have to use env — you can instead enter the client id/secret once in
# the Connectors UI; Pragya saves them encrypted server-side and connecting is
# one-click from then on (env, when set, takes precedence).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Web search (now a connector) ----
# Claude's built-in WebSearch/WebFetch (no key). On first boot this flag SEEDS the
# "Web Search" connector (enabled if true); thereafter toggle it in the Connectors
# marketplace. Kept here so existing setups keep working through the migration.
WEB_SEARCH_ENABLED=true

# ---- Finance (Plaid; now a connector) ----
# Platform-level Plaid app keys (like the Google OAuth client) — kept in env, not
# the per-user vault. When set, they enable the "Finance" connector in the
# marketplace (connect banks via Plaid Link in the drawer or the Finance page) and
# seed it on first boot. Personal-use Trial keys from dashboard.plaid.com; treat
# the secret like a password.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Scheduling: digest and finance jobs are run by the `cron` sidecar container,
# which reads the DIGEST_HOUR/MINUTE, FINANCE_SYNC_HOUR/MINUTE, FINANCE_WEEKLY_*
# vars below and calls POST /digests/run, POST /finance/sync, POST /digests/run-weekly.
# The backend itself does NOT run any in-process scheduler.
FINANCE_WEEKLY_ENABLED=true
FINANCE_WEEKLY_DAY=mon

# ---- CORS ----
# Comma-separated web origins allowed to call the API (the web app).
CORS_ALLOW_ORIGINS=http://localhost:3000
