# Expo public env vars — inlined into the client bundle at build/start time.
# Copy this file to `mobile/.env` and fill in the values. Do NOT commit `mobile/.env`.
#
# API_BASE has a safe public default in code; the token must be provided here.
EXPO_PUBLIC_API_BASE=https://api.134-199-180-135.sslip.io
EXPO_PUBLIC_API_TOKEN=your-api-auth-token-here
