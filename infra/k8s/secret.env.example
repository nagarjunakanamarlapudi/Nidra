# ─────────────────────────────────────────────────────────────────────────────
# Template for the `pragya-env` Secret (backend + cronjobs read this via envFrom).
#
#   cp secret.env.example secret.env      # secret.env is gitignored — never commit it
#   # fill values from the repo-root .env, then apply the PROD OVERRIDES marked below
#   kubectl apply -k infra/k8s
#
# Most values mirror the repo-root .env. The PROD OVERRIDE lines are what differ
# from local: the managed-Postgres URL, the DigitalOcean inference gateway, and the
# public sslip.io URLs (filled in once the load balancer has an IP).
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=production
LOG_LEVEL=info

# Auth/crypto — copy from root .env (or generate fresh 32+ char random strings).
APP_SECRET_KEY=
API_AUTH_TOKEN=

# ── PROD OVERRIDE ── Managed Postgres (asyncpg driver + TLS required by DO).
# From: doctl databases connection pragya-db   (swap scheme to postgresql+asyncpg,
# and use ssl=require — NOT sslmode=require — because asyncpg parses ssl).
DATABASE_URL=postgresql+asyncpg://doadmin:PASSWORD@HOST:25060/defaultdb?ssl=require

# ── PROD OVERRIDE ── public URLs (api.<lb-ip-dashed>.sslip.io once the LB is up).
APP_BASE_URL=https://API_HOST
OAUTH_REDIRECT_BASE_URL=https://API_HOST
NEXT_PUBLIC_API_BASE=https://API_HOST
CORS_ALLOW_ORIGINS=https://API_HOST

# ── Agent engine: claude-code via the DigitalOcean inference gateway ──
AGENT_ENGINE=claude-code
# ── PROD OVERRIDE ── point the Claude CLI at DO inference. Leave ANTHROPIC_API_KEY
# and CLAUDE_CODE_OAUTH_TOKEN EMPTY so the gateway auth token wins.
ANTHROPIC_BASE_URL=https://inference.do-ai.run
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
# Must be a model id the DO gateway serves (verify: see README "model" note).
LLM_CHAT_MODEL=

# Embeddings via OpenAI (Ollama is not used in prod).
LLM_EMBEDDING_PROVIDER=openai
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_EMBEDDING_DIM=1536
OPENAI_API_KEY=
OLLAMA_BASE_URL=

# Schedules (also encoded in the CronJob specs; kept here for the app's own use).
DIGEST_ENABLED=true
DIGEST_TIMEZONE=America/Los_Angeles
DIGEST_HOUR=21
DIGEST_MINUTE=0
DREAM_HOUR=0
DREAM_MINUTE=0
OPINIONS_MINUTE=7
FINANCE_SYNC_HOUR=6
FINANCE_SYNC_MINUTE=30
FINANCE_WEEKLY_ENABLED=true
FINANCE_WEEKLY_DAY=mon

# Connectors / integrations — copy from root .env.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
WEB_SEARCH_ENABLED=true
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
